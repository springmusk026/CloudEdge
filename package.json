{
  "name": "cloudedge-cms",
  "version": "1.0.0",
  "private": true,
  "description": "Production-grade blog CMS running 100% on Cloudflare edge infrastructure",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "pnpm --filter @cloudedge/db generate",
    "db:migrate": "pnpm --filter @cloudedge/db migrate",
    "db:seed": "pnpm --filter @cloudedge/db seed",
    "deploy": "turbo deploy",
    "deploy:staging": "turbo deploy -- --env staging",
    "deploy:production": "turbo build && turbo deploy"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250214.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "wrangler": "^3.99.0"
  }
}
